<UserControl x:Class="CityLibraryFund.WPF.Views.LibrariesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="LibrariesView_Loaded">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Библиотеки"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock Text="Справочник библиотек системы"
                       Margin="0,-12,0,0"
                       Style="{StaticResource BodyText}"/>

        </StackPanel>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock Text="Поиск"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <TextBox x:Name="SearchTextBox"
                         TextChanged="SearchTextBox_TextChanged"/>

            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="12,0,0,0">

                <TextBlock Text="Статус"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="StatusComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

            <StackPanel Grid.Column="2"
                        Margin="12,0,0,0">

                <TextBlock Text="Сортировка"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="SortComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      x:Name="LibrariesDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="LibrariesDataGrid_SelectionChanged">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Название"
                                        Binding="{Binding Name}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Адрес"
                                        Binding="{Binding Address}"
                                        Width="220"/>

                    <DataGridTextColumn Header="Телефон"
                                        Binding="{Binding Phone}"
                                        Width="140"/>

                    <DataGridTextColumn Header="Залов"
                                        Binding="{Binding HallsCount}"
                                        Width="90"/>

                    <DataGridTextColumn Header="Экземпляров"
                                        Binding="{Binding LibraryItemsCount}"
                                        Width="120"/>

                </DataGrid.Columns>

            </DataGrid>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <TextBlock Text="Карточка библиотеки"
                                   Margin="0,0,0,20"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="NameTextBlock"
                                   Margin="0,0,0,20"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>

                        <StackPanel>

                            <TextBlock Text="Адрес"
                                       Style="{StaticResource CardTitleText}"/>

                            <TextBlock x:Name="AddressTextBlock"
                                       Margin="0,4,0,16"
                                       Style="{StaticResource BodyText}"
                                       TextWrapping="Wrap"/>

                        </StackPanel>

                        <StackPanel>

                            <TextBlock Text="Телефон"
                                       Style="{StaticResource CardTitleText}"/>

                            <TextBlock x:Name="PhoneTextBlock"
                                       Margin="0,4,0,16"
                                       Style="{StaticResource BodyText}"/>

                        </StackPanel>

                        <StackPanel>

                            <TextBlock Text="Статус"
                                       Style="{StaticResource CardTitleText}"/>

                            <TextBlock x:Name="StatusTextBlock"
                                       Margin="0,4,0,16"
                                       Style="{StaticResource BodyText}"/>

                        </StackPanel>

                        <StackPanel>

                            <TextBlock Text="Количество залов"
                                       Style="{StaticResource CardTitleText}"/>

                            <TextBlock x:Name="HallsCountTextBlock"
                                       Margin="0,4,0,16"
                                       Style="{StaticResource BodyText}"/>

                        </StackPanel>

                        <StackPanel>

                            <TextBlock Text="Количество сотрудников"
                                       Style="{StaticResource CardTitleText}"/>

                            <TextBlock x:Name="EmployeesCountTextBlock"
                                       Margin="0,4,0,16"
                                       Style="{StaticResource BodyText}"/>

                        </StackPanel>

                        <StackPanel>

                            <TextBlock Text="Количество читателей"
                                       Style="{StaticResource CardTitleText}"/>

                            <TextBlock x:Name="ReadersCountTextBlock"
                                       Margin="0,4,0,16"
                                       Style="{StaticResource BodyText}"/>

                        </StackPanel>

                        <StackPanel>

                            <TextBlock Text="Количество экземпляров"
                                       Style="{StaticResource CardTitleText}"/>

                            <TextBlock x:Name="LibraryItemsCountTextBlock"
                                       Margin="0,4,0,16"
                                       Style="{StaticResource BodyText}"/>

                        </StackPanel>

                        <StackPanel>

                            <TextBlock Text="Активные выдачи"
                                       Style="{StaticResource CardTitleText}"/>

                            <TextBlock x:Name="ActiveLoansCountTextBlock"
                                       Margin="0,4,0,16"
                                       Style="{StaticResource BodyText}"/>

                        </StackPanel>

                    </StackPanel>

                </ScrollViewer>

            </Border>

        </Grid>

    </Grid>

</UserControl>