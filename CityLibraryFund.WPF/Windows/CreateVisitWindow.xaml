<Window x:Class="CityLibraryFund.WPF.Windows.CreateVisitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление посещения"
        SizeToContent="Height"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Посещение читального зала"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock Text="Регистрация посещения читателем"
                       Margin="0,-12,0,24"
                       Style="{StaticResource BodyText}"/>

            <TextBlock Text="Читатель"/>

            <ComboBox x:Name="ReaderComboBox"
                      DisplayMemberPath="FullName"
                      SelectedValuePath="Id"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      StaysOpenOnEdit="True"/>

            <TextBlock Text="Зал"/>

            <ComboBox x:Name="HallComboBox"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="Id"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      StaysOpenOnEdit="True"/>

            <TextBlock Text="Дата посещения"/>

            <DatePicker x:Name="VisitDatePicker"/>

        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,24,0,0">

            <Button Content="Сохранить"
                    Width="140"
                    Style="{StaticResource PrimaryButton}"
                    Click="SaveButton_Click"/>

            <Button Content="Отмена"
                    Width="120"
                    Margin="10,4,0,10"
                    Style="{StaticResource SecondaryButton}"
                    Click="CancelButton_Click"/>

        </StackPanel>

    </Grid>

</Window>