<UserControl x:Class="CityLibraryFund.WPF.Views.HallsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="HallsView_Loaded">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Залы"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock Text="Справочник залов библиотечной системы"
                       Margin="0,-12,0,0"
                       Style="{StaticResource BodyText}"/>

        </StackPanel>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock Text="Поиск"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <TextBox x:Name="SearchTextBox"
                         TextChanged="SearchTextBox_TextChanged"/>

            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="12,0,0,0">

                <TextBlock Text="Библиотека"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="LibraryComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

            <StackPanel Grid.Column="2"
                        Margin="12,0,0,0">

                <TextBlock Text="Сортировка"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="SortComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      x:Name="HallsDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="HallsDataGrid_SelectionChanged">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Название"
                                        Binding="{Binding Name}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Библиотека"
                                        Binding="{Binding LibraryName}"
                                        Width="220"/>

                    <DataGridTextColumn Header="Тип"
                                        Binding="{Binding HallType}"
                                        Width="160"/>

                    <DataGridTextColumn Header="Этаж"
                                        Binding="{Binding Floor}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Сотрудников"
                                        Binding="{Binding EmployeesCount}"
                                        Width="110"/>

                    <DataGridTextColumn Header="Экземпляров"
                                        Binding="{Binding LibraryItemsCount}"
                                        Width="120"/>

                </DataGrid.Columns>

            </DataGrid>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto">

                        <StackPanel>

                            <TextBlock Text="Карточка зала"
                                       Margin="0,0,0,20"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <TextBlock x:Name="NameTextBlock"
                                       Margin="0,0,0,20"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <StackPanel>

                                <TextBlock Text="Библиотека"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="LibraryTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Тип зала"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="HallTypeTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Этаж"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="FloorTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Количество сотрудников"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="EmployeesCountTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Количество экземпляров"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="LibraryItemsCountTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Активные выдачи"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="ActiveLoansCountTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Посещения"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="VisitsCountTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                        </StackPanel>

                    </ScrollViewer>

                    <Button Grid.Row="1"
                            Content="Библиотекари зала"
                            x:Name="EmployeesButton"
                            Margin="0,20,0,0"
                            IsEnabled="False"
                            Style="{StaticResource SecondaryButton}"
                            Click="EmployeesButton_Click"/>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</UserControl>