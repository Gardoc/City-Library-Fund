<Window x:Class="CityLibraryFund.WPF.Windows.WorkAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Произведение"
        Height="860"
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="24">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>

                <TextBlock Text="Карточка произведения"
                           Style="{StaticResource HeaderText}"/>

                <TextBlock Text="Основная информация о произведении"
                           Margin="0,-12,0,24"
                           Style="{StaticResource BodyText}"/>

                <TextBlock Text="Название *"/>
                <TextBox x:Name="TitleTextBox"/>

                <TextBlock Text="Тип произведения *"/>
                <ComboBox x:Name="WorkTypeComboBox"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"/>

                <TextBlock Text="Год написания"/>
                <TextBox x:Name="YearWrittenTextBox"
                         PreviewTextInput="NumberOnly_PreviewTextInput"
                          DataObject.Pasting="NumberOnly_Pasting"/>

                <TextBlock Text="Язык"/>
                <TextBox x:Name="LanguageTextBox"/>

                <TextBlock Text="Описание"/>
                <TextBox x:Name="DescriptionTextBox"
                         Height="120"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                <Separator Margin="0,10"/>

                <TextBlock Text="Авторы *"
                           FontWeight="SemiBold"
                           Margin="0,10,0,8"/>

                <TextBlock Text="Поиск автора"
                           Margin="0,0,0,4"/>

                <TextBox x:Name="AuthorSearchTextBox"
                         Height="32"
                         Margin="0,0,0,12"
                         ToolTip="Введите фамилию или имя автора"
                         TextChanged="AuthorSearchTextBox_TextChanged"/>

                <Grid Height="260">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="8">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Все авторы"
                                       FontWeight="SemiBold"/>

                            <ListBox Grid.Row="2"
                                     x:Name="AllAuthorsListBox"
                                     DisplayMemberPath="FullName"/>

                        </Grid>

                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">

                        <Button Content=">"
                                Width="48"
                                Height="36"
                                Margin="0,0,0,10"
                                Style="{StaticResource SecondaryButton}"
                                Click="AddAuthorButton_Click"/>

                        <Button Content="&lt;"
                                Width="48"
                                Height="36"
                                Style="{StaticResource SecondaryButton}"
                                Click="RemoveAuthorButton_Click"/>

                    </StackPanel>

                    <Border Grid.Column="2"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="8">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Авторы произведения"
                                       FontWeight="SemiBold"/>

                            <ListBox Grid.Row="2"
                                     x:Name="SelectedAuthorsListBox"
                                     DisplayMemberPath="FullName"/>

                        </Grid>

                    </Border>

                </Grid>

            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">

                <Button Content="Сохранить"
                        Width="140"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click"/>

                <Button Content="Отмена"
                        Width="120"
                        Margin="10,4,0,10"
                        Style="{StaticResource SecondaryButton}"
                        Click="CancelButton_Click"/>

            </StackPanel>

        </Grid>

    </ScrollViewer>

</Window>