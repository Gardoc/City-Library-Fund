<Window x:Class="CityLibraryFund.WPF.Windows.ReaderAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читатель"
        Height="760"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="24">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>

                <TextBlock Text="Карточка читателя"
                           Style="{StaticResource HeaderText}"/>

                <TextBlock Text="Основная информация о читателе"
                           Margin="0,-12,0,24"
                           Style="{StaticResource BodyText}"/>

                <TextBlock Text="Фамилия *"/>
                <TextBox x:Name="LastNameTextBox"/>

                <TextBlock Text="Имя *"/>
                <TextBox x:Name="FirstNameTextBox"/>

                <TextBlock Text="Отчество"/>
                <TextBox x:Name="PatronymicTextBox"/>

                <TextBlock Text="Дата рождения *"/>
                <DatePicker x:Name="BirthDatePicker"/>

                <TextBlock Text="Тип читателя *"/>
                <ComboBox x:Name="ReaderTypeComboBox"
                          SelectionChanged="ReaderTypeComboBox_SelectionChanged"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"/>

                <TextBlock Text="Библиотека *"/>
                <ComboBox x:Name="LibraryComboBox"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"/>

                <TextBlock Text="Телефон"/>
                <TextBox x:Name="PhoneTextBox"/>

                <TextBlock Text="Email"/>
                <TextBox x:Name="EmailTextBox"/>

                <TextBlock Text="Адрес"/>
                <TextBox x:Name="AddressTextBox"
                         Height="70"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"/>

                <StackPanel x:Name="StudentPanel"
                            Visibility="Collapsed">

                    <Separator Margin="0,10"/>

                    <TextBlock Text="ВУЗ *"/>
                    <TextBox x:Name="UniversityTextBox"/>

                    <TextBlock Text="Факультет *"/>
                    <TextBox x:Name="FacultyTextBox"/>

                    <TextBlock Text="Курс *"/>
                    <TextBox x:Name="CourseTextBox"
                             PreviewTextInput="NumberOnly_PreviewTextInput"
                              DataObject.Pasting="NumberOnly_Pasting"/>

                    <TextBlock Text="Группа *"/>
                    <TextBox x:Name="GroupTextBox"/>

                </StackPanel>

                <StackPanel x:Name="TeacherPanel"
                            Visibility="Collapsed">

                    <Separator Margin="0,10"/>

                    <TextBlock Text="ВУЗ *"/>
                    <TextBox x:Name="TeacherUniversityTextBox"/>

                    <TextBlock Text="Кафедра *"/>
                    <TextBox x:Name="DepartmentTextBox"/>

                </StackPanel>

                <StackPanel x:Name="ScientistPanel"
                            Visibility="Collapsed">

                    <Separator Margin="0,10"/>

                    <TextBlock Text="Организация *"/>
                    <TextBox x:Name="OrganizationTextBox"/>

                    <TextBlock Text="Научная тема *"/>
                    <TextBox x:Name="ScientificTopicTextBox"/>

                </StackPanel>

                <StackPanel x:Name="SchoolerPanel"
                            Visibility="Collapsed">

                    <Separator Margin="0,10"/>

                    <TextBlock Text="Школа *"/>
                    <TextBox x:Name="SchoolTextBox"/>

                    <TextBlock Text="Класс *"/>
                    <TextBox x:Name="ClassNumberTextBox"/>

                </StackPanel>

            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">

                <Button Content="Сохранить"
                        Width="140"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click"/>

                <Button Content="Отмена"
                        Width="120"
                        Margin="10,4,0,10"
                        Style="{StaticResource SecondaryButton}"
                        Click="CancelButton_Click"/>

            </StackPanel>

        </Grid>

    </ScrollViewer>

</Window>