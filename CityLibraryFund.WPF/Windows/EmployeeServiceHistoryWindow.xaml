<Window x:Class="CityLibraryFund.WPF.Windows.EmployeeServiceHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История обслуживания"
        Height="760"
        Width="1100"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundColor}">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="История обслуживания читателей"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock x:Name="EmployeeNameTextBlock"
                       Margin="0,-12,0,0"
                       Style="{StaticResource BodyText}"/>

        </StackPanel>

        <Grid  Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock Text="Дата начала"
                               Margin="0,0,0,4"
                               Style="{StaticResource CardTitleText}"/>

                <DatePicker x:Name="DateFromPicker"/>

            </StackPanel>

            <StackPanel Grid.Column="1"
                            Margin="12,0,0,0">

                <TextBlock Text="Дата окончания"
                               Margin="0,0,0,4"
                               Style="{StaticResource CardTitleText}"/>

                <DatePicker x:Name="DateToPicker"/>

            </StackPanel>

            <Button Grid.Column="2"
                        Content="Показать"
                        Width="140"
                        Height="38"
                        Margin="16,22,0,0"
                        VerticalAlignment="Top"
                        Style="{StaticResource PrimaryButton}"
                        Click="LoadButton_Click"/>

        </Grid>

        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}">

                <StackPanel>

                    <TextBlock Text="Читателей"
                               Style="{StaticResource CardTitleText}"/>

                    <TextBlock x:Name="ReadersCountTextBlock"
                               Margin="0,8,0,0"
                               FontSize="28"
                               FontWeight="SemiBold"/>

                </StackPanel>

            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">

                <StackPanel>

                    <TextBlock Text="Выдач"
                               Style="{StaticResource CardTitleText}"/>

                    <TextBlock x:Name="LoansCountTextBlock"
                               Margin="0,8,0,0"
                               FontSize="28"
                               FontWeight="SemiBold"/>

                </StackPanel>

            </Border>

            <Border Grid.Column="4"
                    Style="{StaticResource CardStyle}">

                <StackPanel>

                    <TextBlock Text="Возвращено"
                               Style="{StaticResource CardTitleText}"/>

                    <TextBlock x:Name="ReturnedCountTextBlock"
                               Margin="0,8,0,0"
                               FontSize="28"
                               FontWeight="SemiBold"/>

                </StackPanel>

            </Border>

            <Border Grid.Column="6"
                    Style="{StaticResource CardStyle}">

                <StackPanel>

                    <TextBlock Text="Активных выдач"
                               Style="{StaticResource CardTitleText}"/>

                    <TextBlock x:Name="ActiveLoansCountTextBlock"
                               Margin="0,8,0,0"
                               FontSize="28"
                               FontWeight="SemiBold"/>

                </StackPanel>

            </Border>

        </Grid>

        <DataGrid x:Name="HistoryDataGrid"
                  Grid.Row="6"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Читатель"
                                    Binding="{Binding ReaderName}"
                                    Width="240"/>

                <DataGridTextColumn Header="Произведение"
                                    Binding="{Binding WorkTitle}"
                                    Width="*"/>

                <DataGridTextColumn Header="Дата выдачи"
                                    Binding="{Binding LoanDate, StringFormat=dd.MM.yyyy}"
                                    Width="130"/>

                <DataGridTextColumn Header="Вернуть до"
                                    Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}"
                                    Width="130"/>

                <DataGridTextColumn Header="Дата возврата"
                                    Binding="{Binding ReturnDate, StringFormat=dd.MM.yyyy}"
                                    Width="140"/>

                <DataGridCheckBoxColumn Header="Возвращено"
                                        Binding="{Binding IsReturned}"
                                        Width="110"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>