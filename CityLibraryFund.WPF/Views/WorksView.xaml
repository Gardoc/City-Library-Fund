<UserControl x:Class="CityLibraryFund.WPF.Views.WorksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="WorksView_Loaded">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Произведения"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock Text="Управление произведениями библиотеки"
                       Margin="0,-12,0,0"
                       Style="{StaticResource BodyText}"/>

        </StackPanel>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock Text="Поиск"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <TextBox x:Name="SearchTextBox"
                         TextChanged="SearchTextBox_TextChanged"/>

            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="12,0,0,0">

                <TextBlock Text="Тип произведения"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="WorkTypeComboBox"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

            <StackPanel Grid.Column="2"
                        Margin="12,0,0,0">

                <TextBlock Text="Язык"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="LanguageComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

            <StackPanel Grid.Column="3"
                        Margin="12,0,0,0">

                <TextBlock Text="Сортировка"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="SortComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">

                    <Button Content="Добавить произведение"
                            Width="180"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButton}"
                            Click="AddButton_Click"/>

                </DockPanel>

                <DataGrid Grid.Row="2"
                          x:Name="WorksDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="WorksDataGrid_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Название"
                                            Binding="{Binding Title}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Тип"
                                            Binding="{Binding WorkType}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Авторы"
                                            Binding="{Binding Authors}"
                                            Width="240"/>

                        <DataGridTextColumn Header="Год"
                                            Binding="{Binding YearWritten}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Изданий"
                                            Binding="{Binding EditionsCount}"
                                            Width="90"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto">

                        <StackPanel>

                            <TextBlock Text="Карточка произведения"
                                       Margin="0,0,0,20"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <TextBlock x:Name="TitleTextBlock"
                                       Margin="0,0,0,20"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <StackPanel>

                                <TextBlock Text="Тип произведения"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="WorkTypeTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Авторы"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="AuthorsTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"
                                           TextWrapping="Wrap"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Год написания"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="YearWrittenTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Язык"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="LanguageTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel x:Name="DescriptionPanel">

                                <TextBlock Text="Описание"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="DescriptionTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"
                                           TextWrapping="Wrap"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Количество изданий"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="EditionsCountTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Количество экземпляров"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="CopiesCountTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel x:Name="LatestEditionPanel">

                                <TextBlock Text="Последнее издание"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="LatestEditionTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"
                                           TextWrapping="Wrap"/>

                            </StackPanel>

                        </StackPanel>

                    </ScrollViewer>

                    <StackPanel Grid.Row="1"
                                Margin="0,20,0,0">

                        <Button Content="Читатели с произведением"
                                x:Name="ReadersWithWorkButton"
                                IsEnabled="False"
                                Style="{StaticResource SecondaryButton}"
                                Click="ReadersWithWorkButton_Click"/>


                        <Button Content="Инвентарные номера"
                                x:Name="InventoryButton"
                                IsEnabled="False"
                                Style="{StaticResource SecondaryButton}"
                                Click="InventoryButton_Click"/>

                        <Button Content="Редактировать"
                                x:Name="EditButton"
                                IsEnabled="False"
                                Style="{StaticResource PrimaryButton}"
                                Click="EditButton_Click"/>

                        <Button Content="Удалить"
                                x:Name="DeleteButton"
                                IsEnabled="False"
                                Style="{StaticResource DangerButton}"
                                Click="DeleteButton_Click"/>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</UserControl>