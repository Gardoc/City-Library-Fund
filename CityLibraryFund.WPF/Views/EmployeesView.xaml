<UserControl x:Class="CityLibraryFund.WPF.Views.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="EmployeesView_Loaded">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Сотрудники"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock Text="Управление сотрудниками библиотеки"
                       Margin="0,-12,0,0"
                       Style="{StaticResource BodyText}"/>

        </StackPanel>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock Text="Поиск"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <TextBox x:Name="SearchTextBox"
                         TextChanged="SearchTextBox_TextChanged"/>

            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="12,0,0,0">

                <TextBlock Text="Роль"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="RoleComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

            <StackPanel Grid.Column="2"
                        Margin="12,0,0,0">

                <TextBlock Text="Статус"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="StatusComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

            <StackPanel Grid.Column="3"
                        Margin="12,0,0,0">

                <TextBlock Text="Сортировка"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="SortComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">

                    <Button Content="Добавить сотрудника"
                            Width="180"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButton}"
                            Click="AddButton_Click"/>

                </DockPanel>

                <DataGrid Grid.Row="2"
                          x:Name="EmployeesDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="EmployeesDataGrid_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ФИО"
                                            Binding="{Binding FullName}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Роль"
                                            Binding="{Binding Role}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Должность"
                                            Binding="{Binding Position}"
                                            Width="180"/>

                        <DataGridCheckBoxColumn Header="Активен"
                                                Binding="{Binding IsActive}"
                                                Width="80"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto">

                        <StackPanel>

                            <TextBlock Text="Карточка сотрудника"
                                       Margin="0,0,0,20"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <TextBlock x:Name="FullNameTextBlock"
                                       Margin="0,0,0,20"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <StackPanel>
                                <TextBlock Text="Роль"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="RoleTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Должность"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="PositionTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Дата приема"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="HireDateTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Логин"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="LoginTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Библиотека"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="LibraryTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Зал"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="HallTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Тип зала"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="HallTypeTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Этаж"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="FloorTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>
                            </StackPanel>

                        </StackPanel>

                    </ScrollViewer>

                    <StackPanel Grid.Row="1"
                                Margin="0,20,0,0">

                        <Button Content="История обслуживания"
        x:Name="ServiceHistoryButton"
        IsEnabled="False"
        Style="{StaticResource SecondaryButton}"
        Click="ServiceHistoryButton_Click"/>

                        <Button Content="Сменить пароль"
                                x:Name="ChangePasswordButton"
                                IsEnabled="False"
                                Style="{StaticResource SecondaryButton}"
                                Click="ChangePasswordButton_Click"/>

                        <Button Content="Редактировать"
                                x:Name="EditButton"
                                IsEnabled="False"
                                Style="{StaticResource PrimaryButton}"
                                Click="EditButton_Click"/>

                        <Button x:Name="DeactivateButton"
                                Content="Деактивировать"
                                IsEnabled="False"
                                Style="{StaticResource DangerButton}"
                                Click="DeactivateButton_Click"/>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</UserControl>