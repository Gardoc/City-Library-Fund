<UserControl x:Class="CityLibraryFund.WPF.Views.AuthorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="AuthorsView_Loaded">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Авторы"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock Text="Управление авторами библиотеки"
                       Margin="0,-12,0,0"
                       Style="{StaticResource BodyText}"/>

        </StackPanel>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock Text="Поиск"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <TextBox x:Name="SearchTextBox"
                         TextChanged="SearchTextBox_TextChanged"/>

            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="12,0,0,0">

                <TextBlock Text="Страна"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="CountryComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

            <StackPanel Grid.Column="2"
                        Margin="12,0,0,0">

                <TextBlock Text="Сортировка"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="SortComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">

                    <Button Content="Добавить автора"
                            Width="180"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButton}"
                            Click="AddButton_Click"/>

                </DockPanel>

                <DataGrid Grid.Row="2"
                          x:Name="AuthorsDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="AuthorsDataGrid_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ФИО"
                                            Binding="{Binding FullName}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Дата рождения"
                                            Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Страна"
                                            Binding="{Binding Country}"
                                            Width="160"/>

                        <DataGridTextColumn Header="Произведений"
                                            Binding="{Binding WorksCount}"
                                            Width="120"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto">

                        <StackPanel>

                            <TextBlock Text="Карточка автора"
                                       Margin="0,0,0,20"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <TextBlock x:Name="FullNameTextBlock"
                                       Margin="0,0,0,20"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <StackPanel>

                                <TextBlock Text="Дата рождения"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="BirthDateTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Страна"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="CountryTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Количество произведений"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="WorksCountTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Количество экземпляров"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="CopiesCountTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel x:Name="LatestWorkPanel">

                                <TextBlock Text="Последнее произведение"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="LatestWorkTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"
                                           TextWrapping="Wrap"/>

                            </StackPanel>

                        </StackPanel>

                    </ScrollViewer>

                    <StackPanel Grid.Row="1"
                                Margin="0,20,0,0">

                        <Button Content="Инвентарные номера"
                                x:Name="InventoryButton"
                                IsEnabled="False"
                                Style="{StaticResource SecondaryButton}"
                                Click="InventoryButton_Click"/>

                        <Button Content="Редактировать"
                                x:Name="EditButton"
                                IsEnabled="False"
                                Style="{StaticResource PrimaryButton}"
                                Click="EditButton_Click"/>

                        <Button Content="Удалить"
                                x:Name="DeleteButton"
                                IsEnabled="False"
                                Style="{StaticResource DangerButton}"
                                Click="DeleteButton_Click"/>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</UserControl>