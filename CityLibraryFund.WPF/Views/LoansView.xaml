<UserControl x:Class="CityLibraryFund.WPF.Views.LoansView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="LoansView_Loaded">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Выдачи литературы"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock Text="Управление выдачами и возвратами литературы"
                       Margin="0,-12,0,0"
                       Style="{StaticResource BodyText}"/>

        </StackPanel>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock Text="Поиск"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <TextBox x:Name="SearchTextBox"
                         TextChanged="SearchTextBox_TextChanged"/>

            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="12,0,0,0">

                <TextBlock Text="Статус"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="StatusComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

            <StackPanel Grid.Column="2"
                        Margin="12,0,0,0">

                <TextBlock Text="Сортировка"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="SortComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">

                    <Button Content="Оформить выдачу"
                            Width="180"
                            DockPanel.Dock="Left"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButton}"
                            Click="IssueLoanButton_Click"/>

                </DockPanel>

                <DataGrid Grid.Row="2"
                          x:Name="LoansDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="LoansDataGrid_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Читатель"
                                            Binding="{Binding ReaderFullName}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Произведение"
                                            Binding="{Binding BookTitle}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Инв. номер"
                                            Binding="{Binding InventoryNumber}"
                                            Width="130"/>

                        <DataGridTextColumn Header="Вернуть до"
                                            Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Статус"
                                            Binding="{Binding Status}"
                                            Width="120"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto">

                        <StackPanel>

                            <TextBlock Text="Карточка выдачи"
                                       Margin="0,0,0,20"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <TextBlock x:Name="BookTitleTextBlock"
                                       Margin="0,0,0,20"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <StackPanel>
                                <TextBlock Text="Читатель"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="ReaderTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Инвентарный номер"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="InventoryTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Дата выдачи"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="IssueDateTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Вернуть до"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="DueDateTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>
                            </StackPanel>

                            <StackPanel x:Name="ReturnDatePanel">

                                <TextBlock Text="Дата возврата"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="ReturnDateTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Статус"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="StatusTextBlock"
                                           Margin="0,4,0,16"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                        </StackPanel>

                    </ScrollViewer>

                    <StackPanel Grid.Row="1"
                                Margin="0,20,0,0">

                        <Button x:Name="ReturnButton"
                                Content="Оформить возврат"
                                IsEnabled="False"
                                Style="{StaticResource PrimaryButton}"
                                Click="ReturnButton_Click"/>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</UserControl>