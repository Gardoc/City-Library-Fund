<Window x:Class="CityLibraryFund.WPF.Windows.EditionAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Издание"
        SizeToContent="Height"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="24">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>

                <TextBlock Text="Карточка издания"
                           Style="{StaticResource HeaderText}"/>

                <TextBlock Text="Основная информация об издании"
                           Margin="0,-12,0,24"
                           Style="{StaticResource BodyText}"/>

                <TextBlock Text="Произведение *"/>

                <ComboBox x:Name="WorkComboBox"
                          DisplayMemberPath="Title"
                          SelectedValuePath="Id"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          StaysOpenOnEdit="True"/>

                <TextBlock Text="Издательство *"/>

                <TextBox x:Name="PublisherTextBox"/>

                <TextBlock Text="Год издания *"/>

                <TextBox x:Name="PublishYearTextBox"
                         PreviewTextInput="NumberOnly_PreviewTextInput"
                         DataObject.Pasting="NumberOnly_Pasting"/>

                <TextBlock Text="ISBN"/>

                <TextBox x:Name="IsbnTextBox"/>

                <TextBlock Text="Количество страниц"/>

                <TextBox x:Name="PageCountTextBox"
                         PreviewTextInput="NumberOnly_PreviewTextInput"
                         DataObject.Pasting="NumberOnly_Pasting"/>

                <TextBlock Text="Номер издания"/>

                <TextBox x:Name="EditionNumberTextBox"
                         PreviewTextInput="NumberOnly_PreviewTextInput"
                         DataObject.Pasting="NumberOnly_Pasting"/>

            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">

                <Button Content="Сохранить"
                        Width="140"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click"/>

                <Button Content="Отмена"
                        Width="120"
                        Margin="10,4,0,10"
                        Style="{StaticResource SecondaryButton}"
                        Click="CancelButton_Click"/>

            </StackPanel>

        </Grid>

    </ScrollViewer>

</Window>