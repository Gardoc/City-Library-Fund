<UserControl x:Class="CityLibraryFund.WPF.Views.EditionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="EditionsView_Loaded">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Издания"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock Text="Управление изданиями библиотеки"
                       Margin="0,-12,0,0"
                       Style="{StaticResource BodyText}"/>

        </StackPanel>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock Text="Поиск"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <TextBox x:Name="SearchTextBox"
                         TextChanged="SearchTextBox_TextChanged"/>

            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="12,0,0,0">

                <TextBlock Text="Тип произведения"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="WorkTypeComboBox"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

            <StackPanel Grid.Column="2"
                        Margin="12,0,0,0">

                <TextBlock Text="Сортировка"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="SortComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">

                    <Button x:Name="AddButton"
                            Content="Добавить издание"
                            Width="180"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButton}"
                            Click="AddButton_Click"/>

                </DockPanel>

                <DataGrid Grid.Row="2"
                          x:Name="EditionsDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="EditionsDataGrid_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Произведение"
                                            Binding="{Binding WorkTitle}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Издательство"
                                            Binding="{Binding Publisher}"
                                            Width="180"/>

                        <DataGridTextColumn Header="Год"
                                            Binding="{Binding PublishYear}"
                                            Width="80"/>

                        <DataGridTextColumn Header="ISBN"
                                            Binding="{Binding Isbn}"
                                            Width="160"/>

                        <DataGridTextColumn Header="Экземпляров"
                                            Binding="{Binding CopiesCount}"
                                            Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto">

                        <StackPanel>

                            <TextBlock Text="Карточка издания"
                                       Margin="0,0,0,20"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <TextBlock x:Name="WorkTitleTextBlock"
                                       Margin="0,0,0,20"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <StackPanel>

                                <TextBlock Text="Авторы"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="AuthorsTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"
                                           TextWrapping="Wrap"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Тип произведения"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="WorkTypeTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Издательство"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="PublisherTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Год издания"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="PublishYearTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel x:Name="EditionNumberPanel">

                                <TextBlock Text="Номер издания"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="EditionNumberTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel x:Name="IsbnPanel">

                                <TextBlock Text="ISBN"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="IsbnTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel x:Name="PageCountPanel">

                                <TextBlock Text="Количество страниц"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="PageCountTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Язык"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="LanguageTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel>

                                <TextBlock Text="Количество экземпляров"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="CopiesCountTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"/>

                            </StackPanel>

                            <StackPanel x:Name="DescriptionPanel">

                                <TextBlock Text="Описание произведения"
                                           Style="{StaticResource CardTitleText}"/>

                                <TextBlock x:Name="DescriptionTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource BodyText}"
                                           TextWrapping="Wrap"/>

                            </StackPanel>

                        </StackPanel>

                    </ScrollViewer>

                    <StackPanel Grid.Row="1"
                                Margin="0,20,0,0">

                        <Button Content="Читатели на руках"
        x:Name="ReadersButton"
        IsEnabled="False"
        Style="{StaticResource SecondaryButton}"
        Click="ReadersButton_Click"/>

                        <Button Content="Редактировать"
                                x:Name="EditButton"
                                IsEnabled="False"
                                Style="{StaticResource PrimaryButton}"
                                Click="EditButton_Click"/>

                        <Button Content="Удалить"
                                x:Name="DeleteButton"
                                IsEnabled="False"
                                Style="{StaticResource DangerButton}"
                                Click="DeleteButton_Click"/>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</UserControl>