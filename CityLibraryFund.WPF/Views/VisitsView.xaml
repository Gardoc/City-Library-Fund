<UserControl x:Class="CityLibraryFund.WPF.Views.VisitsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="VisitsView_Loaded">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Посещения"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock Text="Учет посещений читальных залов"
                       Margin="0,-12,0,0"
                       Style="{StaticResource BodyText}"/>

        </StackPanel>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock Text="Поиск"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <TextBox x:Name="SearchTextBox"
                         TextChanged="SearchTextBox_TextChanged"/>

            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="12,0,0,0">

                <TextBlock Text="Зал"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="HallComboBox"
                          SelectionChanged="Filter_Changed"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"/>

            </StackPanel>

            <StackPanel Grid.Column="2"
                        Margin="12,0,0,0">

                <TextBlock Text="Сортировка"
                           Margin="0,0,0,4"
                           Style="{StaticResource CardTitleText}"/>

                <ComboBox x:Name="SortComboBox"
                          SelectionChanged="Filter_Changed"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">

                    <Button Content="Добавить посещение"
                            Width="180"
                            DockPanel.Dock="Left"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButton}"
                            Click="AddVisitButton_Click"/>

                </DockPanel>

                <DataGrid Grid.Row="2"
                          x:Name="VisitsDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="VisitsDataGrid_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Читатель"
                                            Binding="{Binding ReaderFullName}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Библиотека"
                                            Binding="{Binding LibraryName}"
                                            Width="220"/>

                        <DataGridTextColumn Header="Зал"
                                            Binding="{Binding HallName}"
                                            Width="180"/>

                        <DataGridTextColumn Header="Сотрудник"
                                            Binding="{Binding EmployeeFullName}"
                                            Width="220"/>

                        <DataGridTextColumn Header="Дата посещения"
                                            Binding="{Binding VisitDate, StringFormat=dd.MM.yyyy HH:mm}"
                                            Width="170"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <TextBlock Text="Карточка посещения"
                                   Margin="0,0,0,20"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="ReaderTextBlock"
                                   Margin="0,0,0,20"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>

                        <StackPanel>

                            <TextBlock Text="Библиотека"
                                       Style="{StaticResource CardTitleText}"/>

                            <TextBlock x:Name="LibraryTextBlock"
                                       Margin="0,4,0,16"
                                       Style="{StaticResource BodyText}"
                                       TextWrapping="Wrap"/>

                        </StackPanel>

                        <StackPanel>

                            <TextBlock Text="Зал"
                                       Style="{StaticResource CardTitleText}"/>

                            <TextBlock x:Name="HallTextBlock"
                                       Margin="0,4,0,16"
                                       Style="{StaticResource BodyText}"
                                       TextWrapping="Wrap"/>

                        </StackPanel>

                        <StackPanel>

                            <TextBlock Text="Сотрудник"
                                       Style="{StaticResource CardTitleText}"/>

                            <TextBlock x:Name="EmployeeTextBlock"
                                       Margin="0,4,0,16"
                                       Style="{StaticResource BodyText}"
                                       TextWrapping="Wrap"/>

                        </StackPanel>

                        <StackPanel>

                            <TextBlock Text="Дата посещения"
                                       Style="{StaticResource CardTitleText}"/>

                            <TextBlock x:Name="VisitDateTextBlock"
                                       Margin="0,4,0,16"
                                       Style="{StaticResource BodyText}"/>

                        </StackPanel>

                    </StackPanel>

                </ScrollViewer>

            </Border>

        </Grid>

    </Grid>

</UserControl>