<Window x:Class="CityLibraryFund.WPF.Windows.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Смена пароля"
        SizeToContent="Height"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Смена пароля"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock x:Name="EmployeeTextBlock"
                       Margin="0,-12,0,24"
                       Style="{StaticResource BodyText}"/>

            <TextBlock Text="Текущий пароль *"/>
            <PasswordBox x:Name="OldPasswordBox"/>

            <TextBlock Text="Новый пароль *"/>
            <PasswordBox x:Name="NewPasswordBox"/>

        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,24,0,0">

            <Button Content="Сохранить"
                    Width="140"
                    Style="{StaticResource PrimaryButton}"
                    Click="SaveButton_Click"/>

            <Button Content="Отмена"
                    Width="120"
                    Margin="10,4,0,10"
                    Style="{StaticResource SecondaryButton}"
                    Click="CancelButton_Click"/>

        </StackPanel>

    </Grid>

</Window>