<Window x:Class="CityLibraryFund.WPF.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="City Library Fund"
        Width="800"
        Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.7*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid Background="{StaticResource SidebarColor}">

            <Grid Margin="50">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="City Library Fund"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="White"/>

                    <TextBlock Text="Информационная система&#10;библиотечного фонда"
                               Margin="0,18,0,0"
                               FontSize="16"
                               Foreground="#CBD5E1"
                               LineHeight="28"/>

                    <Rectangle Width="90"
                               Height="2"
                               Margin="0,30"
                               Fill="#475569"
                               HorizontalAlignment="Left"/>

                    <StackPanel>

                        <TextBlock Text="• Учет библиотечного фонда"
                                   Margin="0,0,0,12"
                                   FontSize="14"
                                   Foreground="#E2E8F0"/>

                        <TextBlock Text="• Регистрация читателей"
                                   Margin="0,0,0,12"
                                   FontSize="14"
                                   Foreground="#E2E8F0"/>

                        <TextBlock Text="• Выдача и возврат литературы"
                                   Margin="0,0,0,12"
                                   FontSize="14"
                                   Foreground="#E2E8F0"/>

                        <TextBlock Text="• Контроль посещений"
                                   Margin="0,0,0,12"
                                   FontSize="14"
                                   Foreground="#E2E8F0"/>

                        <TextBlock Text="• Работа с каталогом"
                                   FontSize="14"
                                   Foreground="#E2E8F0"/>

                    </StackPanel>

                </StackPanel>

            </Grid>

        </Grid>

        <Grid Grid.Column="1">

            <Grid Width="360"
                  VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Вход в систему"
                               Style="{StaticResource HeaderText}"/>

                    <TextBlock Text="Логин"
                               Style="{StaticResource BodyText}"/>

                    <TextBox x:Name="LoginTextBox"/>

                    <TextBlock Text="Пароль"
                               Margin="0,8,0,0"
                               Style="{StaticResource BodyText}"/>

                    <PasswordBox x:Name="PasswordBox"/>

                    <Button Content="Войти"
                            Margin="0,18,0,0"
                            Style="{StaticResource PrimaryButton}"
                            Click="LoginButton_Click"/>

                </StackPanel>

            </Grid>

        </Grid>

    </Grid>

</Window>