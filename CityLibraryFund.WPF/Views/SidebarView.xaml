<UserControl x:Class="CityLibraryFund.WPF.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource SidebarColor}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Margin="10">

            <TextBlock Text="City Library Fund"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="White"/>

            <TextBlock x:Name="UserTextBlock"
                       Margin="0,8,0,0"
                       Foreground="#CBD5E1"/>

            <TextBlock x:Name="RoleTextBlock"
                       Margin="0,2,0,0"
                       FontSize="12"
                       Foreground="#94A3B8"/>

            <Border Margin="0,4,0,0"
            Padding="10"
            CornerRadius="8"
            Background="#1E293B">

                <StackPanel>

                    <TextBlock Text="Библиотека"
                       FontSize="11"
                       Foreground="#94A3B8"/>

                    <TextBlock x:Name="LibraryTextBlock"
                       Margin="0,2,0,10"
                       Foreground="White"
                       TextWrapping="Wrap"/>

                    <TextBlock Text="Зал"
                       FontSize="11"
                       Foreground="#94A3B8"/>

                    <TextBlock x:Name="HallTextBlock"
                       Margin="0,2,0,0"
                       Foreground="White"
                       TextWrapping="Wrap"/>

                </StackPanel>

            </Border>

        </StackPanel>

        <StackPanel Grid.Row="1"
                    Margin="10,20,10,0">

            <Button x:Name="LibrariesButton"
                    Content="Библиотеки"
                    Style="{StaticResource SidebarButton}"
                    Tag="Libraries"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="HallsButton"
                    Content="Залы"
                    Style="{StaticResource SidebarButton}"
                    Tag="Halls"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="AuthorsButton"
                    Content="Авторы"
                    Style="{StaticResource SidebarButton}"
                    Tag="Authors"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="WorksButton"
                    Content="Произведения"
                    Style="{StaticResource SidebarButton}"
                    Tag="Works"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="EditionsButton"
                    Content="Издания"
                    Style="{StaticResource SidebarButton}"
                    Tag="Editions"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="LibraryItemsButton"
                    Content="Экземпляры"
                    Style="{StaticResource SidebarButton}"
                    Tag="LibraryItems"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="EmployeesButton"
                    Content="Сотрудники"
                    Style="{StaticResource SidebarButton}"
                    Tag="Employees"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="ReadersButton"
                    Content="Читатели"
                    Style="{StaticResource SidebarButton}"
                    Tag="Readers"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="VisitsButton"
                    Content="Посещения"
                    Style="{StaticResource SidebarButton}"
                    Tag="Visits"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="LoansButton"
                    Content="Выдачи"
                    Style="{StaticResource SidebarButton}"
                    Tag="Loans"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="LibrarianLibraryItemsButton"
                    Content="Экземпляры"
                    Style="{StaticResource SidebarButton}"
                    Tag="LibraryItems"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>

            <Button x:Name="GeneralAnalyticsButton"
                    Content="Главная аналитика"
                    Style="{StaticResource SidebarButton}"
                    Tag="GeneralAnalytics"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>


            <Button x:Name="AnalyticQueriesButton"
                    Content="Аналитические запросы"
                    Style="{StaticResource SidebarButton}"
                    Tag="AnalyticQueries"
                    Click="NavigationButton_Click"
                    Visibility="Collapsed"/>

        </StackPanel>

        <Button Grid.Row="2"
                Margin="10"
                Content="Выход"
                Style="{StaticResource DangerButton}"
                Click="LogoutButton_Click"/>

    </Grid>

</UserControl>