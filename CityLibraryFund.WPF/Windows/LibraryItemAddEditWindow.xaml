<Window x:Class="CityLibraryFund.WPF.Windows.LibraryItemAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Экземпляр"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="24">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>

                <TextBlock Text="Карточка экземпляра"
                           Style="{StaticResource HeaderText}"/>

                <TextBlock Text="Основная информация об экземпляре"
                           Margin="0,-12,0,24"
                           Style="{StaticResource BodyText}"/>

                <TextBlock Text="Издание *"/>

                <ComboBox x:Name="EditionComboBox"
                          DisplayMemberPath="Work.Title"
                          SelectedValuePath="Id"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          StaysOpenOnEdit="True"/>

                <TextBlock Text="Библиотека *"/>

                <ComboBox x:Name="LibraryComboBox"
          DisplayMemberPath="Name"
          SelectedValuePath="Id"
          SelectionChanged="LibraryComboBox_SelectionChanged"/>

                <TextBlock Text="Зал *"/>

                <ComboBox x:Name="HallComboBox"
          DisplayMemberPath="Name"
          SelectedValuePath="Id"/>

                <TextBlock Text="Инвентарный номер *"/>

                <TextBox x:Name="InventoryNumberTextBox"/>

                <TextBlock Text="Стеллаж *"/>

                <TextBox x:Name="RackNumberTextBox"
                         PreviewTextInput="NumberOnly_PreviewTextInput"
                         DataObject.Pasting="NumberOnly_Pasting"/>

                <TextBlock Text="Полка *"/>

                <TextBox x:Name="ShelfNumberTextBox"/>

                <CheckBox x:Name="OnlyReadingRoomCheckBox"
                          Margin="0,16,0,0"
                          Content="Только читальный зал"
                          Checked="OnlyReadingRoomCheckBox_Changed"
                          Unchecked="OnlyReadingRoomCheckBox_Changed"/>

                <TextBlock Text="Срок выдачи (дней)"
                           x:Name="LoanDaysTextBlock"/>

                <TextBox x:Name="LoanDaysTextBox"
                         PreviewTextInput="NumberOnly_PreviewTextInput"
                         DataObject.Pasting="NumberOnly_Pasting"/>

                <TextBlock Text="Дата поступления *"/>

                <DatePicker x:Name="ArrivalDatePicker"/>

                <TextBlock Text="Цена"/>

                <TextBox x:Name="PriceTextBox"/>

            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">

                <Button Content="Сохранить"
                        Width="140"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click"/>

                <Button Content="Отмена"
                        Width="120"
                        Margin="10,4,0,10"
                        Style="{StaticResource SecondaryButton}"
                        Click="CancelButton_Click"/>

            </StackPanel>

        </Grid>

    </ScrollViewer>

</Window>