<Window x:Class="CityLibraryFund.WPF.Windows.AuthorInventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Экземпляры автора"
        Height="600"
        Width="900"
        MinHeight="400"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundColor}">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Экземпляры произведений автора"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock x:Name="AuthorNameTextBlock"
                       Margin="0,-12,0,0"
                       Style="{StaticResource BodyText}"/>

        </StackPanel>

        <DataGrid x:Name="InventoryDataGrid"  Grid.Row="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Инвентарный номер"
                                        Binding="{Binding InventoryNumber}"
                                        Width="180"/>

                <DataGridTextColumn Header="Произведение"
                                        Binding="{Binding WorkTitle}"
                                        Width="*"/>

                <DataGridTextColumn Header="Библиотека"
                                        Binding="{Binding LibraryName}"
                                        Width="260"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>