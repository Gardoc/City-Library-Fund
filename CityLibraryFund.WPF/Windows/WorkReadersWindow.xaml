<Window x:Class="CityLibraryFund.WPF.Windows.WorkReadersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читатели произведения"
        Height="600"
        Width="1000"
        MinHeight="400"
        MinWidth="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundColor}">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Читатели с произведением на руках"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock x:Name="WorkTitleTextBlock"
                       Margin="0,-12,0,0"
                       Style="{StaticResource BodyText}"
                       TextWrapping="Wrap"/>

        </StackPanel>

        <DataGrid x:Name="ReadersDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Читатель"
                                    Binding="{Binding ReaderFullName}"
                                    Width="*"/>

                <DataGridTextColumn Header="Телефон"
                                    Binding="{Binding Phone}"
                                    Width="170"/>

                <DataGridTextColumn Header="Библиотека"
                                    Binding="{Binding LibraryName}"
                                    Width="240"/>

                <DataGridTextColumn Header="Дата выдачи"
                                    Binding="{Binding IssueDate, StringFormat=dd.MM.yyyy}"
                                    Width="130"/>

                <DataGridTextColumn Header="Вернуть до"
                                    Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}"
                                    Width="130"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>