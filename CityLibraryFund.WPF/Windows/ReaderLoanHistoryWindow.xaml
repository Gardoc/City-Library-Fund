<Window x:Class="CityLibraryFund.WPF.Windows.ReaderLoanHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История выдач"
        Height="600"
        Width="900"
        MinHeight="400"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundColor}">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="История выдач читателя"
                       Style="{StaticResource HeaderText}"/>

            <TextBlock x:Name="ReaderNameTextBlock"
                       Margin="0,-12,0,0"
                       Style="{StaticResource BodyText}"/>

        </StackPanel>

        <DataGrid x:Name="HistoryDataGrid"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Название произведения"
                                        Binding="{Binding BookTitle}"
                                        Width="*"/>

                <DataGridTextColumn Header="Дата выдачи"
                                        Binding="{Binding LoanDate, StringFormat=dd.MM.yyyy}"
                                        Width="130"/>

                <DataGridTextColumn Header="Вернуть до"
                                        Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}"
                                        Width="130"/>

                <DataGridTextColumn Header="Дата возврата"
                                        Binding="{Binding ReturnDate, StringFormat=dd.MM.yyyy}"
                                        Width="140"/>

                <DataGridCheckBoxColumn Header="Возвращено"
                                            Binding="{Binding IsReturned}"
                                            Width="110"/>

                <DataGridCheckBoxColumn Header="Просрочка"
                                            Binding="{Binding IsOverdue}"
                                            Width="100"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>